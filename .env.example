# AI Gateway environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# In docker-compose, REDIS_ADDR / CLICKHOUSE_ADDR / PORT are overridden
# with container DNS names, so the values below are for bare-metal runs.

# ---------------------------------------------------------------------------
# Redis (hot state: tokens, CB credits, disabled flags, gateway keys, rate)
# ---------------------------------------------------------------------------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# Log backend (request/response history for /history* endpoints)
# ---------------------------------------------------------------------------
#   LOG_BACKEND=sqlite      (default) → embedded modernc.org/sqlite, ~0 ops cost
#   LOG_BACKEND=clickhouse            → external ClickHouse (analytics)
#
# SQLite stores the DB file at LOG_SQLITE_PATH (default below). Persist this
# path across container restarts by mounting a docker volume onto it.
# ---------------------------------------------------------------------------
LOG_BACKEND=sqlite
LOG_SQLITE_PATH=/var/lib/foxrouters/logs.db

# ---------------------------------------------------------------------------
# ClickHouse (only used when LOG_BACKEND=clickhouse — full request/response
# JSON, 90d TTL, analytics-optimised). Native protocol port 9000, NOT HTTP.
# Database auto-created on first boot if missing.
# ---------------------------------------------------------------------------
CLICKHOUSE_ADDR=127.0.0.1:9000
CLICKHOUSE_DB=foxrouters
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
PORT=20130

# ---------------------------------------------------------------------------
# Bootstrap credentials (first-run seed only — persisted to Redis after)
# After first boot, Redis is the single source of truth and these are unused.
# Leave empty to manage credentials via REST API instead.
# ---------------------------------------------------------------------------
# GATEWAY_KEY_FILE=./gateway-key.txt
# GATEWAY_API_KEYS=            # comma-separated gateway keys
# CB_KEY_FILE=./codebuddy-key.txt
# CB_API_KEYS=                 # comma-separated CodeBuddy keys

# ---------------------------------------------------------------------------
# Dev override — set to `1` to disable Bearer auth on all endpoints.
# LEAVE EMPTY IN PRODUCTION.
# ---------------------------------------------------------------------------
GATEWAY_AUTH_DISABLE=

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (first-class Go feature, v1.6.0)
#
# The gateway now runs cloudflared as an embedded subprocess (data plane)
# and drives named-tunnel lifecycle via the cloudflare-go v7 SDK (control
# plane). One container, no separate tunnel container.
#
# Runtime configuration lives in Redis (`fr:tunnel:config`) so mode +
# credentials survive restarts and are managed from the dashboard's
# "Tunnel" page (or the /api/tunnel/* endpoints).
#
# The env vars below are optional seeds only:
#   - CLOUDFLARED_PATH:  where the manager finds the cloudflared binary
#                        (auto-set to /usr/local/bin/cloudflared inside
#                        the Docker image).
#   - TUNNEL_UPSTREAM_URL: what cloudflared proxies to. Defaults to
#                         http://127.0.0.1:<PORT>. Override only if the
#                         gateway binds to a non-loopback interface.
#
# Legacy TUNNEL_MODE (read by install.sh + old tunnel.sh) is still
# honoured for install-time defaults, but runtime state is Redis-driven.
# ---------------------------------------------------------------------------
CLOUDFLARED_PATH=/usr/local/bin/cloudflared
# TUNNEL_UPSTREAM_URL=http://127.0.0.1:20130

# Named-tunnel credentials — optional seed only, normally set via the
# dashboard's Tunnel page. When present at boot AND the persisted mode
# is `named` or `hybrid` with no stored credentials, they seed Redis.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
# TUNNEL_DOMAIN=

# Install-time default used by install.sh (none|quick|named).
TUNNEL_MODE=none
